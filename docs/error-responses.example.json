{
  "_comment": "Error response shapes for Dakoppervlakte API routes. The /api/searches handlers (POST/DELETE/GET) intentionally have no try/catch — unhandled errors (e.g. 'relation searches does not exist') surface as Next.js default 500 HTML pages, not JSON. The explicit entries below are the JSON shapes we DO emit.",
  "/api/searches": {
    "401_unauthorized_GET": {
      "error": "Unauthorized"
    },
    "401_unauthorized_POST": {
      "error": "Unauthorized"
    },
    "401_unauthorized_DELETE": {
      "error": "Unauthorized"
    },
    "400_missing_id_DELETE": {
      "error": "Missing ID"
    }
  },
  "/api/counter": {
    "500_init_retry_failed_POST": {
      "count": null,
      "debug": "init-retry-failed"
    },
    "500_generic_error_POST": {
      "count": null,
      "debug": "connection timeout"
    },
    "fallback_GET_on_table_missing": {
      "count": 0
    },
    "fallback_GET_on_generic_error": {
      "count": 0,
      "debug": "connection timeout"
    }
  },
  "/api/autogen-counter": {
    "500_init_retry_failed_POST": {
      "count": null,
      "debug": "init-retry-failed"
    },
    "500_generic_error_POST": {
      "count": null,
      "debug": "connection timeout"
    },
    "fallback_GET_on_table_missing": {
      "count": 0
    },
    "fallback_GET_on_generic_error": {
      "count": 0,
      "debug": "connection timeout"
    }
  },
  "/api/building-polygon": {
    "400_missing_params": {
      "error": "Missing lat/lng"
    },
    "no_building_found": {
      "features": [],
      "debug": {
        "lat": "51.2211",
        "lng": "4.3997",
        "msg": "No building found"
      }
    }
  },
  "/api/init": {
    "500_database_url_not_set": {
      "error": "DATABASE_URL not set"
    },
    "500_generic_error": {
      "error": "connection refused"
    }
  }
}
