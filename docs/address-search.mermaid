sequenceDiagram
    autonumber

    participant User
    participant App as DakoppervlakteApp
    participant AS as AddressSearch
    participant GEO as useGeocoding
    participant GC as google.maps.Geocoder
    participant Map as google.maps.Map
    participant PD as usePolygonDrawing

    User ->> AS: Types address, presses Enter or clicks Search
    activate AS
    AS ->> App: onSearch()
    deactivate AS

    activate App
    App ->> GEO: geocodeAndNavigate(address, onComplete)
    activate GEO

    GEO ->> GEO: setSearching(true), setSearchError('')

    GEO ->> GC: geocode({ address: address + ', Belgium', region: 'BE' })
    activate GC

    alt Geocoding succeeds
        GC -->> GEO: results[0].geometry.location
        deactivate GC

        GEO ->> Map: setCenter(location)
        GEO ->> Map: setZoom(20)
        GEO ->> GEO: setSearching(false)
        GEO -->> App: onComplete()
        deactivate GEO

        Note over App,PD: 600ms delay before auto-starting drawing mode
        App ->> PD: startDrawing()

    else Geocoding fails or no results
        GC -->> GEO: error or empty results
        GEO ->> GEO: setSearchError(t('Errors.addressNotFound'))
        GEO ->> GEO: setSearching(false)
        deactivate GEO
    end
    deactivate App
